# Shared password the whole team logs in with.
APP_PASSWORD=changeme

# Secret used to sign the session cookie (HMAC). Generate with:
#   openssl rand -hex 32
SESSION_SECRET=dev-secret-change-me

# Optional: path prefix the app is served under behind the gateway (e.g. /plan).
# Baked at build time — only needed for the containerized/gateway deploy.
# NEXT_PUBLIC_BASE_PATH=/plan

# Optional: explicit public origin for absolute links behind a tunnel.
# PUBLIC_APP_URL=
